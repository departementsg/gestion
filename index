<!DOCTYPE html>
<html lang="fr">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=7" />
  <title>Gestion des Spécialités — Web Version</title>
  <style type="text/css">
    body { font-family: Arial, sans-serif; margin:10px; color:#222; background:#fff; }
    h2 { color:#1565C0; text-transform:uppercase; font-size:16px; text-align:center; margin-bottom:10px; }

    .form-container { overflow:hidden; padding:8px 12px; }

    .controls-row {
      white-space: nowrap;
      overflow: auto;
      padding: 8px 0;
      zoom: 1;
    }

    .ctrl {
      display: inline-block;
      *display: inline;
      zoom: 1;
      vertical-align: top;
      margin-right: 12px;
      box-sizing: border-box;
      text-align: left;
    }

    .ctrl.select { width: 200px; }
    .ctrl.medium { width: 180px; }
    .ctrl.long   { width: 300px; }
    .ctrl.short  { width: 90px; }

    .ctrl-label {
      display: block;
      height: 18px;
      line-height: 18px;
      font-size: 12px;
      color: #333;
      margin: 0 0 6px 0;
    }

    select, input[type="text"] {
      width: 100%;
      padding:6px;
      box-sizing: border-box;
      height: 30px;
      font-size:13px;
      color: #000 !important;
      background: #fff !important;
      margin: 0;
      vertical-align: top;
    }
    option { color:#000 !important; background:#fff !important; }

    .buttons-row { text-align:center; margin-top:8px; padding-top:6px; clear: both; }
    .buttons-row button {
      display:inline-block;
      margin: 0 8px;
      padding:6px 12px;
      background:#1565C0;
      color:#fff;
      border:none;
      cursor:pointer;
      height:32px;
      line-height:16px;
    }

    table { width:100%; border-collapse:collapse; margin-top:12px; font-size:13px; }
    th, td { border:1px solid #B0BEC5; padding:8px; text-align:left; vertical-align:top; }
    th { background:#1565C0; color:#fff; text-transform:uppercase; font-size:12px; }
    tr:nth-child(even) { background:#F5F5F5; }
    tr.selected { background:#D0E8FF !important; }
    tr:hover { background:#EEF7FF; cursor:pointer; }

    .msg { margin-top:8px; color:green; text-align:center; }
    .err { margin-top:8px; color:red; text-align:center; }
    .small { font-size:12px; color:#555; text-align:center; }
  </style>
</head>
<body>
  <h2>Gestion des Spécialités</h2>

  <div class="form-container">
    <div class="controls-row" id="controlsRow">
      <div class="ctrl select" id="c-filiere">
        <label class="ctrl-label" for="filiere">Filière</label>
        <select id="filiere" title="Filière"></select>
      </div>

      <div class="ctrl short" id="c-niveau">
        <label class="ctrl-label" for="niveau">Niveau</label>
        <select id="niveau" title="Niveau">
          <option value="">--Niveau--</option>
          <option value="L1">L1</option>
          <option value="L2">L2</option>
          <option value="L3">L3</option>
          <option value="Master">Master</option>
        </select>
      </div>

      <div class="ctrl short" id="c-semestre">
        <label class="ctrl-label" for="semestre">Semestre</label>
        <select id="semestre" title="Semestre">
          <option value="">--Sem--</option>
          <option value="Pair">Pair</option>
          <option value="Impair">Impair</option>
        </select>
      </div>

      <div class="ctrl long" id="c-special">
        <label class="ctrl-label" for="special">Spécialité</label>
        <input id="special" type="text" placeholder="Spécialité" title="Spécialité" />
      </div>

      <div class="ctrl medium" id="c-abrevi">
        <label class="ctrl-label" for="abrevi">Abréviation</label>
        <input id="abrevi" type="text" placeholder="Abrév." title="Abréviation" />
      </div>

      <div class="ctrl short" id="c-nbremat">
        <label class="ctrl-label" for="nbreMat">Nbre de Mat.</label>
        <select id="nbreMat" title="Nbre de Mat."></select>
      </div>

      <div class="ctrl short" id="c-nbreGpes">
        <label class="ctrl-label" for="nbreGpes">Nbre Gpes TD</label>
        <select id="nbreGpes" title="Nbre Gpes TD"></select>
      </div>

      <div class="ctrl medium" id="c-arrete">
        <label class="ctrl-label" for="arrete">Arrêté</label>
        <input id="arrete" type="text" placeholder="Arrêté" title="Arrêté" />
      </div>
    </div>

    <div class="buttons-row" id="buttonsRow">
      <button id="btnAdd">Ajouter</button>
      <button id="btnUpdate">Mettre à jour</button>
      <button id="btnDelete">Supprimer</button>
    </div>
  </div>

  <div id="feedback" class="small"></div>

  <table id="tbl" cellpadding="0" cellspacing="0">
    <thead>
      <tr>
        <th>Filière</th><th>Niveau</th><th>Semestre</th><th>Spécialité</th><th>Abréviation</th><th>Nbre Mat.</th><th>Nbre Gpes TD</th><th>Arrêté</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

<script type="text/javascript">
// Remplacez par votre repo : https://raw.githubusercontent.com/OWNER/REPO/main/
var baseRawUrl = 'https://raw.githubusercontent.com/departementsg/gestion/main/'; // Modifié pour votre repo

function showMsg(text){ var d=document.getElementById('feedback'); d.className='msg'; d.innerText=text; setTimeout(function(){ if(d.className==='msg') d.innerText=''; },4000); }
function showErr(text){ var d=document.getElementById('feedback'); d.className='err'; d.innerText=text; setTimeout(function(){ if(d.className==='err') d.innerText=''; },6000); }

function sanitizeField(s){ if (!s) return ""; return String(s).replace(/;/g,",").replace(/^\s+|\s+$/g,""); }

function setOptionColors(opt){
  try{ if (opt && opt.style){ opt.style.color = "#000"; opt.style.background = "#fff"; } }catch(e){}
}

function populateNumberSelect(id, min, max, placeholder){
  var sel = document.getElementById(id);
  if (!sel) return;
  while (sel.options.length > 0) sel.remove(0);
  var opt0 = document.createElement('option'); opt0.value = ""; opt0.text = placeholder || "--";
  setOptionColors(opt0); sel.add(opt0);
  for (var n = min; n <= max; n++){
    var o = document.createElement('option'); o.value = String(n);
    try { o.text = String(n); } catch(e) { o.innerText = String(n); }
    setOptionColors(o);
    sel.add(o);
  }
  try { sel.style.color = "#000"; sel.style.background = "#fff"; } catch(e){}
}

// Charger Filiere.txt depuis GitHub
function loadFiliereFromGitHub() {
  fetch(baseRawUrl + 'Filiere.txt')
    .then(response => {
      if (!response.ok) throw new Error('Fichier Filiere.txt non trouvé');
      return response.text();
    })
    .then(text => {
      var filiereList = [];
      var lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
      var start = lines.length > 0 && lines[0].toLowerCase().indexOf('domaine') !== -1 ? 1 : 0;
      for (var i = start; i < lines.length; i++) {
        var L = lines[i].trim();
        if (!L) continue;
        var cols = L.split(';');
        var fil = cols[1] ? cols[1].trim() : '';
        var ab = cols[2] ? cols[2].trim() : '';
        if (fil) filiereList.push({ filiere: fil, abrevi: ab });
      }
      localStorage.setItem('filiereData', JSON.stringify(filiereList));
      loadFiliereListToSelect();
    })
    .catch(err => {
      console.warn('Erreur chargement Filiere.txt:', err);
      loadFiliereListToSelect(); // Fallback vide
    });
}

function loadFiliereListToSelect() {
  var filiereList = JSON.parse(localStorage.getItem('filiereData') || '[]');
  var sel = document.getElementById('filiere');
  if (!sel) return;
  var cur = sel.value || "";
  while (sel.options.length>0) sel.remove(0);
  var opt0 = document.createElement('option'); opt0.value=""; opt0.text="-- Filière --"; setOptionColors(opt0); sel.add(opt0);
  for (var m=0;m<filiereList.length;m++){
    var o = document.createElement('option'); o.value = filiereList[m].filiere;
    try { o.text = filiereList[m].filiere; } catch(e) { o.innerText = filiereList[m].filiere; }
    if (filiereList[m].abrevi) o.setAttribute('data-abrevi', filiereList[m].abrevi);
    setOptionColors(o); sel.add(o);
  }
  try { sel.style.color = "#000"; sel.style.background = "#fff"; if (cur) sel.value = cur; } catch(e) {}
}

function onFiliereChange() {
  var sel = document.getElementById('filiere');
  if (!sel) return;
  var idx = sel.selectedIndex; if (idx < 0) return;
  var a = sel.options[idx].getAttribute('data-abrevi') || "";
  try { document.getElementById('abrevi').value = a; } catch(e) {}
}

// Charger Specialite.txt depuis GitHub
function loadSpecialiteFromGitHub() {
  fetch(baseRawUrl + 'Specialite.txt')
    .then(response => {
      if (!response.ok) throw new Error('Fichier Specialite.txt non trouvé');
      return response.text();
    })
    .then(text => {
      var data = [];
      var lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
      var hasHeader = lines.length > 0 && lines[0].toLowerCase().indexOf('filiere') !== -1;
      for (var i = hasHeader ? 1 : 0; i < lines.length; i++) {
        var L = lines[i].trim();
        if (!L) continue;
        var cols = L.split(';');
        data.push({
          filiere: cols[0] ? cols[0].trim() : '',
          niveau: cols[1] ? cols[1].trim() : '',
          semestre: cols[2] ? cols[2].trim() : '',
          specialite: cols[3] ? cols[3].trim() : '',
          abrevi: cols[4] ? cols[4].trim() : '',
          nbreMat: cols[5] ? cols[5].trim() : '',
          nbreGpes: cols[6] ? cols[6].trim() : '',
          arrete: cols[7] ? cols[7].trim() : ''
        });
      }
      localStorage.setItem('specialiteData', JSON.stringify(data));
      loadSpecialiteData();
    })
    .catch(err => {
      console.warn('Erreur chargement Specialite.txt:', err);
      loadSpecialiteData(); // Fallback vide
    });
}

function addRowToTable(filiere, niveau, semestre, special, abrevi, nbreMat, nbreGpes, arrete, index){
  var tbody = document.getElementById('tbl').getElementsByTagName('tbody')[0];
  var tr = document.createElement('tr');
  var td1=document.createElement('td'); td1.innerText=filiere;
  var td2=document.createElement('td'); td2.innerText=niveau;
  var td3=document.createElement('td'); td3.innerText=semestre;
  var td4=document.createElement('td'); td4.innerText=special;
  var td5=document.createElement('td'); td5.innerText=abrevi;
  var td6=document.createElement('td'); td6.innerText=nbreMat;
  var td7=document.createElement('td'); td7.innerText=nbreGpes;
  var td8=document.createElement('td'); td8.innerText=arrete;
  tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3); tr.appendChild(td4); tr.appendChild(td5); tr.appendChild(td6); tr.appendChild(td7); tr.appendChild(td8);
  if (index !== undefined) { try { tr.setAttribute('data-index', String(index)); } catch(e) {} }

  tr.onclick = function(){
    var sel = document.getElementById('filiere');
    var matched=false;
    for (var i=0;i<sel.options.length;i++){ if (sel.options[i].value === filiere) { sel.selectedIndex = i; matched=true; break; } }
    if (!matched){ var tmp=document.createElement('option'); tmp.value=filiere; try{tmp.text=filiere;}catch(e){tmp.innerText=filiere;} if (abrevi) tmp.setAttribute('data-abrevi',abrevi); setOptionColors(tmp); sel.add(tmp); sel.selectedIndex = sel.options.length-1; }
    try{ document.getElementById('abrevi').value = abrevi; }catch(e){}
    try{ document.getElementById('niveau').value = niveau; }catch(e){}
    try{ document.getElementById('semestre').value = semestre; }catch(e){}
    try{ document.getElementById('special').value = special; }catch(e){}
    try{ document.getElementById('nbreMat').value = nbreMat; }catch(e){}
    try{ document.getElementById('nbreGpes').value = nbreGpes; }catch(e){}
    try{ document.getElementById('arrete').value = arrete; }catch(e){}
    var rows = document.getElementById('tbl').getElementsByTagName('tbody')[0].getElementsByTagName('tr');
    for (var r=0;r<rows.length;r++){ if (rows[r]===tr) rows[r].className='selected'; else if (rows[r].className==='selected') rows[r].className=''; }
  };

  tbody.appendChild(tr);
}

function loadSpecialiteData(){
  var tbody = document.getElementById('tbl').getElementsByTagName('tbody')[0];
  while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
  var data = JSON.parse(localStorage.getItem('specialiteData') || '[]');
  for (var i=0; i<data.length; i++){
    var item = data[i];
    addRowToTable(item.filiere, item.niveau, item.semestre, item.specialite, item.abrevi, item.nbreMat, item.nbreGpes, item.arrete, i);
  }
}

function saveSpecialiteData(data){
  localStorage.setItem('specialiteData', JSON.stringify(data));
}

function getSelectedRowAndIndex(){
  var tbody = document.getElementById('tbl').getElementsByTagName('tbody')[0];
  var rows = tbody.getElementsByTagName('tr');
  for (var i=0;i<rows.length;i++){
    if (rows[i].className === 'selected') {
      var idx = rows[i].getAttribute('data-index');
      return { tr: rows[i], index: idx ? parseInt(idx, 10) : null };
    }
  }
  return { tr: null, index: null };
}

function validNotEmpty(s){ return (s!==null && s!==undefined && String(s).replace(/^\s+|\s+$/g,'').length>0); }

window.onload = function(){
  populateNumberSelect('nbreMat', 1, 40, '-- Nbre Mat --');
  populateNumberSelect('nbreGpes', 1, 300, '-- Nbre Gpes --');

  // Charger depuis GitHub
  loadFiliereFromGitHub();
  loadSpecialiteFromGitHub();

  var selF = document.getElementById('filiere');
  if (selF) {
    if (selF.attachEvent) selF.attachEvent('onchange', onFiliereChange);
    else selF.onchange = onFiliereChange;
  }

  function centerButtons() {
    try {
      var controlsRow = document.getElementById('controlsRow');
      var buttonsRow = document.getElementById('buttonsRow');
      if (!controlsRow || !buttonsRow) return;
      var crRect = controlsRow.getBoundingClientRect ? controlsRow.getBoundingClientRect() : null;
      var contRect = (document.querySelector('.form-container') || document.body).getBoundingClientRect ? (document.querySelector('.form-container') || document.body).getBoundingClientRect() : null;
      var left = 0, width = controlsRow.offsetWidth || 0;
      if (crRect && contRect) left = crRect.left - contRect.left;
      var buttons = buttonsRow.getElementsByTagName('button');
      var total = 0;
      for (var i=0;i<buttons.length;i++){ total += buttons[i].offsetWidth || 0; if (i>0) total += 16; }
      var paddingLeft = Math.round(left + (width - total)/2);
      if (paddingLeft < 0) paddingLeft = 0;
      buttonsRow.style.paddingLeft = paddingLeft + 'px';
    } catch (e) {}
  }
  setTimeout(centerButtons, 120);
  if (window.attachEvent) window.attachEvent('onresize', centerButtons); else window.onresize = centerButtons;

  document.getElementById('btnAdd').onclick = function() {
    var sel = document.getElementById('filiere');
    var filiere = sanitizeField(sel ? sel.value : "");
    var niveau  = sanitizeField(document.getElementById('niveau').value || "");
    var semestre= sanitizeField(document.getElementById('semestre').value || "");
    var special = sanitizeField(document.getElementById('special').value || "");
    var ab = "";
    try { if (sel && sel.selectedIndex >= 0) ab = sel.options[sel.selectedIndex].getAttribute('data-abrevi') || ""; } catch(e) {}
    var abrevi  = sanitizeField(document.getElementById('abrevi').value || ab || "");
    var nbreMat = sanitizeField(document.getElementById('nbreMat').value || "");
    var nbreGpes= sanitizeField(document.getElementById('nbreGpes').value || "");
    var arrete  = sanitizeField(document.getElementById('arrete').value || "");
    if (!validNotEmpty(filiere)) { showErr("Le champ Filière est requis."); return; }
    if (!validNotEmpty(special))  { showErr("Le champ Spécialité est requis."); return; }
    var data = JSON.parse(localStorage.getItem('specialiteData') || '[]');
    data.push({filiere:filiere, niveau:niveau, semestre:semestre, specialite:special, abrevi:abrevi, nbreMat:nbreMat, nbreGpes:nbreGpes, arrete:arrete});
    saveSpecialiteData(data);
    loadSpecialiteData();
    try { document.getElementById('filiere').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('niveau').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('semestre').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('special').value = ""; } catch(e) {}
    try { document.getElementById('abrevi').value = ""; } catch(e) {}
    try { document.getElementById('nbreMat').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('nbreGpes').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('arrete').value = ""; } catch(e) {}
    showMsg("Ajouté et enregistré.");
    setTimeout(centerButtons, 80);
  };

  document.getElementById('btnUpdate').onclick = function() {
    var selRow = getSelectedRowAndIndex();
    if (!selRow.tr || selRow.index === null) { showErr("Sélectionnez d'abord une ligne à mettre à jour."); return; }
    var sel = document.getElementById('filiere');
    var filiere = sanitizeField(sel ? sel.value : "");
    var niveau  = sanitizeField(document.getElementById('niveau').value || "");
    var semestre= sanitizeField(document.getElementById('semestre').value || "");
    var special = sanitizeField(document.getElementById('special').value || "");
    var ab = "";
    try { if (sel && sel.selectedIndex>=0) ab = sel.options[sel.selectedIndex].getAttribute('data-abrevi') || ""; } catch(e) {}
    var abrevi  = sanitizeField(document.getElementById('abrevi').value || ab || "");
    var nbreMat = sanitizeField(document.getElementById('nbreMat').value || "");
    var nbreGpes= sanitizeField(document.getElementById('nbreGpes').value || "");
    var arrete  = sanitizeField(document.getElementById('arrete').value || "");
    if (!validNotEmpty(filiere)) { showErr("Le champ Filière est requis."); return; }
    if (!validNotEmpty(special))  { showErr("Le champ Spécialité est requis."); return; }
    var data = JSON.parse(localStorage.getItem('specialiteData') || '[]');
    data[selRow.index] = {filiere:filiere, niveau:niveau, semestre:semestre, specialite:special, abrevi:abrevi, nbreMat:nbreMat, nbreGpes:nbreGpes, arrete:arrete};
    saveSpecialiteData(data);
    loadSpecialiteData();
    showMsg("Ligne mise à jour.");
    setTimeout(centerButtons, 80);
  };

  document.getElementById('btnDelete').onclick = function() {
    var selRow = getSelectedRowAndIndex();
    if (!selRow.tr || selRow.index === null) { showErr("Sélectionnez d'abord une ligne à supprimer."); return; }
    if (!confirm("Confirmer la suppression de la ligne sélectionnée ?")) return;
    var data = JSON.parse(localStorage.getItem('specialiteData') || '[]');
    data.splice(selRow.index, 1);
    saveSpecialiteData(data);
    loadSpecialiteData();
    try { document.getElementById('filiere').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('niveau').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('semestre').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('special').value = ""; } catch(e) {}
    try { document.getElementById('abrevi').value = ""; } catch(e) {}
    try { document.getElementById('nbreMat').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('nbreGpes').selectedIndex = 0; } catch(e) {}
    try { document.getElementById('arrete').value = ""; } catch(e) {}
    showMsg("Ligne supprimée.");
    setTimeout(centerButtons, 80);
  };
};
</script>
</body>
</html>
